{
  "manifest_version": 3,
  "name": "One Expand Prospects",
  "version": "2.0.0",
  "description": "Scrape Google Maps leads: phone, email, social media, reviews. No API key. Country/State/City/Niche search builder.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://*/*",
    "http://*/*",
    "https://oneexpandcrm.lovable.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "One Expand Prospects",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}